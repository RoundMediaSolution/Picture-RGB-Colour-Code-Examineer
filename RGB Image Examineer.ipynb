from PIL import Image
import numpy as np
import sys
import os
import csv


output_filename = "pixel_data_output.csv"


img_path = "Picture1.png"
try:
    img = Image.open(img_path)
    print(f"Image '{img_path}' loaded successfully.")
    print(f"Image format: {img.format}, size: {img.size}, mode: {img.mode}")
except FileNotFoundError:
    print(f"Error: Image file '{img_path}' not found. Please upload it to Colab.")
    sys.exit(1)
except Exception as e:
    print(f"An error occurred while opening the image: {e}")
    sys.exit(1)

print("\nOriginal Image:")
display(img)

img_array = np.array(img)

print(f"\nImage converted to NumPy array with shape: {img_array.shape}")
print(f"Data type of pixel values: {img_array.dtype}")
print(f"Total number of pixels: {img_array.shape[0] * img_array.shape[1]}")


print(f"\nWriting ALL pixel RGB and Hex values to '{output_filename}' (CSV format)...")

with open(output_filename, 'w', newline='') as csvfile:
    csv_writer = csv.writer(csvfile)

    if img_array.ndim == 3 and img_array.shape[-1] >= 3:
        height, width, _ = img_array.shape

        csv_writer.writerow(["X", "Y", "R", "G", "B", "Hex"])

        for y in range(height):
            for x in range(width):
                r, g, b = img_array[y, x, :3]
                hex_color = f"#{r:02x}{g:02x}{b:02x}"

                csv_writer.writerow([x, y, r, g, b, hex_color])
    elif img_array.ndim == 2:
        height, width = img_array.shape
        csv_writer.writerow(["X", "Y", "Intensity"])
        print("Image is grayscale. Saving intensity values to CSV file.")
        for y in range(height):
            for x in range(width):
                intensity = img_array[y, x]
                csv_writer.writerow([x, y, intensity])
    else:
        csv_writer.writerow(["Unsupported image format (neither RGB nor grayscale)."])
        print("Unsupported image format (neither RGB nor grayscale).")

print(f"Successfully saved all pixel data to '{output_filename}' in your Colab environment.")
print("You can find and download this file using the folder icon (Files) on the left sidebar.")

if img_array.ndim == 3 and img_array.shape[-1] >= 3:
    r_channel = img_array[:, :, 0]
    g_channel = img_array[:, :, 1]
    b_channel = img_array[:, :, 2]

    print(f"\nShape of Red channel: {r_channel.shape}")
    print(f"Shape of Green channel: {g_channel.shape}")
    print(f"Shape of Blue channel: {b_channel.shape}")
    print("Individual R, G, B channel arrays are created but not printed entirely to console.")
else:
    print("\nSkipping channel separation as image is not RGB.")
